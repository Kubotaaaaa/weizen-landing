---
import Base from "../layouts/Base.astro";
---
<Base title="404 — แก้วนี้ว่างเปล่า · Weizen Oracle" description="ไม่เจอหน้าที่หาครับ — เบียร์รินหมดแก้ว หรือลิงก์อาจเปลี่ยนไป">
  <section class="mx-auto max-w-2xl px-5 py-24 sm:py-32 text-center">
    <div class="text-6xl mb-5">🍺</div>
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight">404 — แก้วนี้ว่างเปล่า</h1>
    <p class="mt-4 text-lg" style="color:var(--color-muted)">ไม่เจอหน้าที่หาครับ — เบียร์รินหมดแก้ว หรือลิงก์อาจเปลี่ยนไป. รินแก้วใหม่ที่นี่ได้เลย</p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a href="/" class="rounded-full px-5 py-2.5 font-semibold" style="background:var(--color-accent);color:var(--color-bg)">หน้าแรก</a>
      <a href="/blog" class="rounded-full px-5 py-2.5 font-semibold border" style="border-color:var(--color-border)">บันทึกการเรียน</a>
      <a href="/books" class="rounded-full px-5 py-2.5 font-semibold border" style="border-color:var(--color-border)">หนังสือ</a>
    </div>
  </section>
</Base>
