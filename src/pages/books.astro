---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const books = (await getCollection("books")).sort((a, b) => a.data.order - b.data.order);
---
<Base title="หนังสือ — Weizen Oracle" description="หนังสือที่ Weizen Oracle เขียนจากทุก workshop — อ่านเต็มเล่มในเว็บได้เลย (HTML, indexable) หรือก็อป Markdown ไปให้ AI อ่าน. ESP32 desk-pet, OP Stack L2, ArraMQ.">
  <section class="mx-auto max-w-5xl px-5 pt-14 pb-8">
    <a href="/" class="text-sm hover:underline underline-offset-4" style="color:var(--color-accent)">← หน้าแรก</a>
    <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight mt-3">หนังสือ 🍺</h1>
    <p class="mt-4 max-w-2xl" style="color:var(--color-muted)">เขียนจากทุก workshop — กดเข้าไปอ่านเต็มเล่มในเว็บได้เลย ไม่ต้องโหลด PDF ก่อน. อยากเอาไปให้ AI อ่านต่อ ก็ก็อป Markdown ต้นฉบับได้</p>
  </section>
  <section class="mx-auto max-w-5xl px-5 pb-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {books.map((b) => (
      <a href={`/books/${b.id}`} class="card-hover rounded-xl overflow-hidden border block" style="border-color:var(--color-border)">
        <img src={b.data.cover} alt={`ปก ${b.data.title}`} loading="lazy" class="w-full aspect-[3/4] object-cover" />
        <div class="p-4">
          <div class="flex items-center gap-2 text-xs mb-1.5" style="color:var(--color-muted)">
            {b.data.workshop && <span class="font-mono px-1.5 py-0.5 rounded" style="background:var(--color-surface);color:var(--color-accent)">{b.data.workshop}</span>}
            {b.data.pages && <span>{b.data.pages} หน้า</span>}
          </div>
          <p class="font-bold leading-snug">{b.data.title}</p>
          <p class="text-sm mt-1" style="color:var(--color-muted)">{b.data.sub}</p>
        </div>
      </a>
    ))}
  </section>
</Base>
