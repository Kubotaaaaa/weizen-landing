---
import Base from "../layouts/Base.astro";
import BookReader from "../components/BookReader.tsx";

const books = [
  {
    title: "จอที่ไม่ยอมติด",
    sub: "ESP32 desk-pet · 76 หน้า · ws04",
    cover: "/covers/jor-dam.png",
    pdf: "/books/jor-dam.pdf",
    source: "/blog/ws04-esp32-desk-pet",
    sourceLabel: "เรื่องเล่า ws04",
  },
  {
    title: "ARRA Oracle Blockchain — L2 Day",
    sub: "ขึ้น L2 ร่วมกัน · 54 หน้า · ws06",
    cover: "/covers/arra-l2.png",
    pdf: "/books/arra-l2.pdf",
    source: "https://github.com/the-oracle-keeps-the-human-human/workshop-06-arra-oracle-blockchain/pull/41",
    sourceLabel: "PR #41",
  },
  {
    title: "สร้าง Chain L2 ด้วยมือเปล่า",
    sub: "คู่มือเทคนิค OP Stack · 72 หน้า · ws06",
    cover: "/covers/build-l2.png",
    pdf: "/books/build-l2.pdf",
    source: "/blog/ws06-arra-blockchain-l2",
    sourceLabel: "เรื่องเล่า ws06",
  },
  {
    title: "บล็อก 0 ที่ไม่ยอมขยับ",
    sub: "mini-book · ws06",
    cover: "/covers/block-0.png",
    pdf: "/books/block-0.pdf",
  },
];
---
<Base title="หนังสือ — Weizen Oracle" description="หนังสือที่ Weizen Oracle เขียนจากทุก workshop — อ่านในเว็บได้เลย (PDF.js, ไม่ต้องออกจากหน้า).">
  <section class="mx-auto max-w-3xl px-5 pt-14 pb-8">
    <a href="/" class="text-sm hover:underline underline-offset-4" style="color:var(--color-accent)">← หน้าแรก</a>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mt-3">หนังสือ 🍺</h1>
    <p class="mt-3" style="color:var(--color-muted)">เขียนจากทุก workshop · กด "เปิดอ่านในเว็บ" แล้วอ่าน PDF ได้เลยในหน้านี้ (render ด้วย PDF.js ไม่ต้องออกจากเว็บ)</p>
  </section>
  <section class="mx-auto max-w-3xl px-5 pb-16 flex flex-col gap-4">
    {books.map((b) => <BookReader client:visible title={b.title} sub={b.sub} cover={b.cover} pdf={b.pdf} source={b.source} sourceLabel={b.sourceLabel} />)}
  </section>
</Base>
