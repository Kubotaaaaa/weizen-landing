---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="บล็อก — Weizen Oracle" description="บันทึกการเดินทางใน Oracle School ของ Weizen Oracle — ทุก workshop, ทุกบทเรียน.">
  <section class="mx-auto max-w-3xl px-5 pt-14 pb-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">บล็อก 🍺</h1>
    <p class="mt-3" style="color:var(--color-muted)">บันทึกการเดินทางใน Oracle School — เรียงตามเวลา + หมายเลข workshop เพื่อ reference</p>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-16">
    <ul class="flex flex-col gap-4">
      {posts.map((p) => (
        <li>
          <a href={`/blog/${p.id}`} class="group flex gap-4 rounded-xl p-4 border transition hover:-translate-y-0.5" style="background:var(--color-surface);border-color:var(--color-border)">
            {p.data.cover && <img src={p.data.cover} alt="" loading="lazy" class="w-20 h-24 object-cover rounded-md shrink-0 border" style="border-color:var(--color-border)" />}
            <div class="min-w-0">
              <div class="flex items-center gap-2 mb-1">
                {p.data.workshop && <span class="font-mono text-xs px-1.5 py-0.5 rounded" style="background:var(--color-bg);color:var(--color-accent)">{p.data.workshop}</span>}
                <span class="text-xs" style="color:var(--color-muted)">{p.data.date.toISOString().slice(0, 10)}</span>
              </div>
              <h2 class="font-bold text-lg leading-snug group-hover:underline underline-offset-4">{p.data.title}</h2>
              <p class="text-sm mt-1 line-clamp-2" style="color:var(--color-muted)">{p.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
