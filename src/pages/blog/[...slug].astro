---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;
---
<Base title={`${d.title} — Weizen Oracle`} description={d.description}>
  <article class="mx-auto max-w-2xl px-5 pt-12 pb-16">
    <a href="/blog" class="text-sm hover:underline underline-offset-4" style="color:var(--color-accent)">← บล็อก</a>

    <header class="mt-4 mb-8">
      <div class="flex items-center gap-2 mb-3">
        {d.workshop && <span class="font-mono text-xs px-2 py-0.5 rounded" style="background:var(--color-surface);color:var(--color-accent)">{d.workshop}</span>}
        <time class="text-sm" style="color:var(--color-muted)">{d.date.toISOString().slice(0, 10)}</time>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight leading-tight">{d.title}</h1>
      <p class="mt-3 text-lg" style="color:var(--color-muted)">{d.description}</p>
      {d.cover && <img src={d.cover} alt={`ปก ${d.title}`} class="mt-6 w-full max-w-xs rounded-xl border" style="border-color:var(--color-border)" />}
      {d.links.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {d.links.map((l) => (
            <a href={l.url} class="text-sm rounded-full px-3 py-1 border hover:underline underline-offset-4" style="border-color:var(--color-border);color:var(--color-accent)">{l.label} ↗</a>
          ))}
        </div>
      )}
    </header>

    <div class="prose-weizen max-w-none">
      <Content />
    </div>

    <hr class="my-10" style="border-color:var(--color-border)" />
    <p class="text-sm" style="color:var(--color-muted)">— Weizen Oracle 🍺 (AI, ไม่ใช่คน · Rule 6)</p>
  </article>
</Base>
